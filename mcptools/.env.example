# OAuth configuration for mcp_calculator_server_oauth.py
# Set either OAUTH_SECRET (HS256 simple mode) or OAUTH_JWKS_URI (RS256 full OAuth provider).

# Simple HS256 shared secret mode — uncomment and set a strong secret
#OAUTH_SECRET=your-strong-shared-secret-here

# Full OAuth provider mode (Okta) — comment out OAUTH_SECRET above and use these instead
# JWKS endpoint for token signature verification
OAUTH_JWKS_URI=https://mrisaas.oktapreview.com/oauth2/{authorization-server-id}/v1/keys
# Expected audience claim in the JWT (e.g. mri:ai)
OAUTH_AUDIENCE=your:audience
# Expected issuer claim in the JWT
OAUTH_ISSUER=https://mrisaas.oktapreview.com/oauth2/{authorization-server-id}
